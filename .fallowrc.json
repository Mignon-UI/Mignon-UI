{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "static/**",
    "public/sql-wasm.js",
    "public/sql-wasm.wasm"
  ],
  "ignoreExports": [
    {
      "file": "src/services/api.js",
      "exports": ["*"]
    },
    {
      "file": "src/services/crud.js",
      "exports": ["*"]
    }
  ]
}
